# Database (Vercel Marketplace → Neon Postgres)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth
# - AUTH_SECRET: HMAC key for magic-link tokens and session cookies.
#   Generate with: openssl rand -hex 32
# - ALLOWED_EMAILS: comma- or whitespace-separated list of emails allowed
#   to sign in. Anyone not on this list is rejected at /api/auth/request.
AUTH_SECRET="change-me"
ALLOWED_EMAILS="you@example.com"

# Resend (Vercel Marketplace → Resend) — used for magic links + change alerts
RESEND_API_KEY="re_..."
RESEND_FROM="Pagedog <noreply@yourdomain.cz>"

# Cron auth — generate with: openssl rand -hex 32
CRON_SECRET="change-me"

# Public URL (used in magic-link emails + change notifications)
APP_URL="http://localhost:3000"
