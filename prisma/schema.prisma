generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Watch {
  id            String    @id @default(cuid())
  userId        String
  label         String
  url           String
  selector      String
  notifyEmail   String
  lastValue     String?
  lastHash      String?
  lastCheckedAt DateTime?
  lastError     String?
  isActive      Boolean   @default(true)
  intervalMinutes Int     @default(60)
  createdAt     DateTime  @default(now())
  changes       Change[]
  checks        Check[]

  @@index([userId])
  @@index([isActive])
}

model Change {
  id         String   @id @default(cuid())
  watchId    String
  oldValue   String
  newValue   String
  detectedAt DateTime @default(now())
  watch      Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([watchId])
}

model Check {
  id        String   @id @default(cuid())
  watchId   String
  status    String   // "same" | "changed" | "error"
  value     String?
  error     String?
  durationMs Int?
  checkedAt DateTime @default(now())
  watch     Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([watchId, checkedAt])
}
